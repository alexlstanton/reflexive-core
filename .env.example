# Anthropic Claude API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Supported models (Feb 2026):
#   claude-sonnet-4-5-20250929  (Sonnet 4.5 - Oct 2025 baseline)
#   claude-opus-4-5-20251101    (Opus 4.5)
#   claude-sonnet-4-6           (Sonnet 4.6 - Feb 2026)
#   claude-opus-4-6             (Opus 4.6 - Feb 2026 flagship)
# Note: run_sweep.py ignores this and tests all models automatically
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI API Configuration (for future multi-provider sweep)
OPENAI_API_KEY=your_openai_api_key_here
# Supported models: gpt-5, gpt-5-mini
OPENAI_MODEL=gpt-5

# Google Gemini API Configuration (for future multi-provider sweep)
GEMINI_API_KEY=your_gemini_api_key_here
# Supported models: gemini-2.5-pro-latest, gemini-2.5-flash-latest
GEMINI_MODEL=gemini-2.5-pro-latest

# Test Configuration
MAX_TOKENS=4096
TEMPERATURE=0.7
TIMEOUT_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=data/logs/testbed.log

# Analysis Settings
SIMILARITY_THRESHOLD=0.85
CONFIDENCE_MIN=0.0
CONFIDENCE_MAX=1.0
